# AI Models (required for AI analysis)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Polymarket (required for live trading only)
POLY_PRIVATE_KEY=0x...
POLY_FUNDER_ADDRESS=0x...
POLY_SIGNATURE_TYPE=1
# 0 = EOA (own wallet, needs MATIC for gas)
# 1 = Magic/Email Login (export via reveal.magic.link/polymarket)
# 2 = Gnosis Safe (MetaMask/Rabby)
